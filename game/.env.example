# Copy to .env and set your key (do not commit .env)
# Or put key in public/config.json: { "aihubmixApiKey": "sk-..." }
VITE_AIHUBMIX_API_KEY=sk-your-aihubmix-key

# Engine v2: set to 1 or true to enable design-seed + Planner dynamic outline (requires key + design-seed.json)
VITE_AI_ENGINE_V2=0

# Optional per-agent models (defaults to gpt-4o-mini if unset)
# VITE_AI_MODEL_DEFAULT=gpt-4o-mini
# VITE_AI_MODEL_PLANNER=gpt-4o
# VITE_AI_MODEL_DIRECTOR=gpt-4o-mini
# VITE_AI_MODEL_WRITER=gpt-4o-mini
# VITE_AI_MODEL_CHOICE=gpt-4o-mini
# VITE_AI_MODEL_VERIFIER=gpt-4o-mini
# VITE_AI_MODEL_YISHI=gpt-4o-mini
