{
  "name": "another-history",
  "private": true,
  "version": "3.0.0",
  "description": "Another History — narrative game (Vite + React + Electron)",
  "author": "Another History contributors",
  "type": "module",
  "main": "electron/main.cjs",
  "scripts": {
    "copy-fonts": "node scripts/copy-fonts.mjs",
    "postinstall": "node scripts/copy-fonts.mjs",
    "dev": "vite",
    "build": "npm run copy-fonts && tsc -b && vite build",
    "preview": "vite preview",
    "electron:dev": "npx --yes kill-port 5173 5174 5175 && concurrently \"vite\" \"wait-on http://localhost:5173 && electron .\"",
    "electron:build": "npm run build",
    "electron:pack": "npm run build && electron-builder --win",
    "test:ai": "node scripts/ai-regression.mjs",
    "test:unit": "vitest run",
    "test": "npm run test:unit && npm run test:ai",
    "format:skeleton": "node scripts/format-json.mjs public/data/skeleton.json",
    "generate:prologue": "node scripts/generate-chapter.mjs prologue",
    "generate:prologue:force": "node scripts/generate-chapter.mjs prologue --force",
    "generate": "node scripts/generate-chapter.mjs",
    "generate:all": "node scripts/generate-chapter.mjs --all"
  },
  "dependencies": {
    "@chinese-fonts/mzxst": "^3.0.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "@vitejs/plugin-react": "^4.3.3",
    "autoprefixer": "^10.4.20",
    "concurrently": "^9.1.0",
    "electron": "^33.2.0",
    "electron-builder": "^25.1.8",
    "postcss": "^8.4.49",
    "tailwindcss": "^3.4.15",
    "typescript": "~5.6.2",
    "vite": "^6.0.1",
    "vitest": "^3.2.4",
    "wait-on": "^8.0.1"
  },
  "build": {
    "appId": "com.anotherhistory.game",
    "productName": "Another History",
    "directories": {
      "output": "release"
    },
    "files": [
      "dist/**/*",
      "electron/**/*",
      "package.json"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "signAndEditExecutable": false
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
