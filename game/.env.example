# Copy to .env (do not commit .env)
# OpenAI-compatible API (any provider with /v1/chat/completions)

# Preferred: key + optional base URL
# 若同时在游戏门闸保存了 Key，运行时会优先用门闸/localStorage，不会用这里的 Key。
VITE_OPENAI_API_KEY=
# Root URL including /v1, e.g. https://api.openai.com/v1 or https://aihubmix.com/v1
VITE_OPENAI_BASE_URL=https://api.openai.com/v1

# Legacy alias (still supported)
# VITE_AIHUBMIX_API_KEY=

# Optional: public/config.json (gitignored) can set:
# { "openaiApiKey": "...", "openaiBaseUrl": "https://...", "openaiModel": "gpt-4o-mini" }

# Engine v2: default on in code; set to 0 or false to disable Planner / dynamic outline
VITE_AI_ENGINE_V2=1

# Models: used when the in-game gate leaves「模型」empty. Otherwise gate model overrides all roles.
# VITE_AI_MODEL_DEFAULT=gpt-4o-mini
# VITE_AI_MODEL_PLANNER=gpt-4o
# VITE_AI_MODEL_DIRECTOR=gpt-4o-mini
# VITE_AI_MODEL_WRITER=gpt-4o-mini
# VITE_AI_MODEL_CHOICE=gpt-4o-mini
# VITE_AI_MODEL_VERIFIER=gpt-4o-mini
# VITE_AI_MODEL_YISHI=gpt-4o-mini

# VITE_AI_DEBUG=1
