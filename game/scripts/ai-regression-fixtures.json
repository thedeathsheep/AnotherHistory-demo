{
  "staticCases": [
    {
      "id": "plot_guide_hit",
      "output": "雾起折戟原，脚边土路发硬。",
      "plotGuide": ["折戟原"],
      "expectMatch": true
    },
    {
      "id": "plot_guide_miss",
      "output": "只有白雾，听不见人声。",
      "plotGuide": ["折戟原", "铁锈"],
      "expectMatch": false
    },
    {
      "id": "taboo_keyword_stripped",
      "output": "你停步，不敢回头。",
      "plotGuide": ["禁忌：回头"],
      "expectMatch": true
    },
    {
      "id": "short_keyword_ignored",
      "output": "路。",
      "plotGuide": ["x"],
      "expectMatch": false
    }
  ],
  "tabooCases": [
    {
      "id": "taboo_narrative_hit",
      "text": "你推开庙门，霉味扑面。",
      "taboo": ["庙"],
      "expectViolates": true
    },
    {
      "id": "taboo_strip_buke",
      "text": "脚下一滑，差点走神。",
      "taboo": ["不可走神"],
      "expectViolates": true
    },
    {
      "id": "taboo_clean",
      "text": "土路发硬，风贴着耳廓过。",
      "taboo": ["庙", "回头"],
      "expectViolates": false
    }
  ],
  "verifyCases": [
    {
      "id": "verify_ok",
      "text": "折戟原上雾浓，铁锈味贴鼻。",
      "plotGuide": ["折戟原"],
      "taboo": [],
      "expectOk": true
    },
    {
      "id": "verify_empty",
      "text": "   ",
      "plotGuide": [],
      "taboo": [],
      "expectOk": false
    },
    {
      "id": "verify_taboo_fail",
      "text": "你推开庙门。",
      "plotGuide": ["路"],
      "taboo": ["庙"],
      "expectOk": false
    }
  ],
  "outlineCases": [
    {
      "id": "outline_valid_min",
      "realmId": "prologue",
      "json": "{\"realm_id\":\"prologue\",\"beats\":[{\"beat_id\":\"b1\",\"type\":\"setup\",\"summary\":\"醒来\",\"tension\":0.2},{\"beat_id\":\"b2\",\"type\":\"rising\",\"summary\":\"辨路\",\"tension\":0.4},{\"beat_id\":\"b3\",\"type\":\"climax\",\"summary\":\"异象\",\"tension\":0.8}]}",
      "expectOk": true
    },
    {
      "id": "outline_wrong_realm",
      "realmId": "prologue",
      "json": "{\"realm_id\":\"other\",\"beats\":[{\"beat_id\":\"b1\",\"type\":\"setup\",\"summary\":\"a\",\"tension\":0.1},{\"beat_id\":\"b2\",\"type\":\"rising\",\"summary\":\"b\",\"tension\":0.2},{\"beat_id\":\"b3\",\"type\":\"rising\",\"summary\":\"c\",\"tension\":0.3}]}",
      "expectOk": false
    },
    {
      "id": "outline_too_few_beats",
      "realmId": "prologue",
      "json": "{\"realm_id\":\"prologue\",\"beats\":[{\"beat_id\":\"b1\",\"type\":\"setup\",\"summary\":\"only\",\"tension\":0.5}]}",
      "expectOk": false
    }
  ]
}
